{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "cc": ["./@types/cc"],
      "cc/env": ["./@types/cc"],
      "db://oops-framework/*": ["./@types/oops-framework"]
    },
    "typeRoots": ["./@types"]
  },
  "include": [
    "assets/script/**/*.ts",
    "@types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "extensions",
    "temp",
    "build"
  ]
}
